# Safaricom Daraja API (leave blank to use simulation mode)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/payments/confirm
MPESA_ENV=sandbox
# CustomerPayBillOnline for paybill | CustomerBuyGoodsOnline for till number
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
# PartyB: same as MPESA_SHORTCODE for paybill, or your till number for buy goods
MPESA_PARTY_B=174379
